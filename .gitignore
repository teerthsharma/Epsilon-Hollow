# =============================================================================
# Epsilon-Hollow Unified Ignore File
# =============================================================================

# --- Legacy Host Script Caches ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.pytest_cache/
venv/
.venv/
env/
ENV/
.coverage
.tox/
htmlcov/
.mypy_cache/

# --- Local Secrets / Machine State ---
.env
.env.*
!.env.example
!.env.sample
*.local

# --- Rust ---
target/
**/target/
target-test-*/
**/target-test-*/
# Cargo.lock is committed for reproducible CI builds
**/*.rs.bk
*.profraw
*.profdata
perf.data
perf.data.*
# Intermediate / incremental artifacts
*.rmeta
*.rlib
*.dylib
*.so
*.dll
*.lib
*.exp
*.ilk
*.manifest
incremental/
**/.rustc_info.json
**/.rustdoc_fingerprint.json
**/.cargo-ok
# Local cargo overrides (keep workspace .cargo/config.toml, ignore local)
.cargo/config.local.toml
# Kernel-specific build directories with non-standard names
kernel/seal-os/target/
kernel/seal-os/target-*/

# --- Node.js / Frontend ---
node_modules/
.next/
out/
.turbo/
npm-debug.log
yarn-error.log
pnpm-debug.log
.pnpm-store/

# --- ML Models & Data (Large Files) ---
BitNet/
models/
**/models/
*.gguf
*.bin
!kernel/seal-os/src/drivers/gpu/shaders/*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.manifold
*.akashic
*.tpu_map

# --- Databases ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite*
*.sqlite3
clara.db
vector_store.db

